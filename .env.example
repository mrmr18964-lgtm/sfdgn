# ╔══════════════════════════════════════════╗
# ║   SUPER AI BOT — muhit o'zgaruvchilari   ║
# ║   Bu faylni .env deb nusxalang           ║
# ║   cp .env.example .env                   ║
# ╚══════════════════════════════════════════╝

# ── Majburiy kalitlar ──────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here
ADMIN_GEMINI_KEY=your_admin_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Admin ID lar (vergul bilan ajrating) ───
# Telegram ID ni bilish uchun botga /myid yozing
ADMIN_IDS=123456789

# ── Render.com Webhook ─────────────────────
# Render da deployment qilingandan keyin URLni oling:
# https://sfdgn.onrender.com
# Bo'sh qolsa — long polling rejimida ishlaydi (lokal test uchun)
WEBHOOK_URL=

# ── SQLite database path ───────────────────
# Render da persistent disk uchun:
# /opt/render/project/src/data/bot_history.db
DB_PATH=bot_history.db

# ── Telegram Mini App (ixtiyoriy) ──────────
# webapp/index.html ni GitHub Pages / Vercel ga joylashtiring
# va URL ni shu yerga kiriting
BOT_WEBAPP_URL=https://myteleapp.netlify.app/

# ── Server port (Render avtomatik beradi) ──
PORT=8443
